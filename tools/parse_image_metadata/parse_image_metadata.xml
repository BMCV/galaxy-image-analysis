<tool name="Parse value from image metadata" id="param_image_metadata" version="0.1.0" tool_type="expression" profile="19.05">
    <description>
        from dataset
    </description>
    <macros>
        <import>creators.xml</import>
    </macros>
    <creator>
        <expand macro="creators/bmcv"/>
        <expand macro="creators/kostrykin"/>
    </creator>
    <macros/>
    <edam_operations>
        <edam_operation>operation_3443</edam_operation>
    </edam_operations>
    <expression type="ecma5.1">
    {
        var output;
        return {
            'width': parseInt($job.input1.metadata.width)
        };
    }
    </expression>
    <inputs>
        <param type="data" format="tiff,ome.tiff,png" label="Input file containing parameter to parse out of" load_contents="0" name="input1"/>
    </inputs>
    <outputs>
        <output type="integer" name="width" from="width"/>
    </outputs>
    <tests>
        <test expect_num_outputs="1">
            <param name="input1" value="input1.tiff"/>
            <output name="width">
                <assert_contents>
                    <has_line line="265"/>
                </assert_contents>
            </output>
        </test>
    </tests>
    <help/>
</tool>
